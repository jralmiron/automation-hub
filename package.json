{
  "name": "automation-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hub de automatizaciones con GitHub Actions y Trigger.dev",
  "scripts": {
    "dev": "node ./node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "check": "node ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "job:daily": "node ./node_modules/tsx/dist/cli.mjs jobs/daily-digest.ts",
    "job:manual": "node ./node_modules/tsx/dist/cli.mjs jobs/manual-run.ts",
    "job:event": "node ./node_modules/tsx/dist/cli.mjs jobs/event-router.ts",
    "job:morning": "node ./node_modules/tsx/dist/cli.mjs jobs/morning-routine.ts",
    "job:tomorrow": "node ./node_modules/tsx/dist/cli.mjs jobs/tomorrow-meetings.ts",
    "job:night": "node ./node_modules/tsx/dist/cli.mjs jobs/night-digest.ts",
    "bridge:test": "node ./node_modules/tsx/dist/cli.mjs scripts/test-telegram-bridge.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "tweetsodium": "^0.0.4",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
