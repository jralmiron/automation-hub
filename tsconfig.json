{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "api/**/*.ts",
    "src/**/*.ts",
    "google/**/*.ts",
    "calendar/**/*.ts",
    "gmail/**/*.ts",
    "telegram/**/*.ts",
    "trigger/**/*.ts",
    "supabase/**/*.ts",
    "jobs/**/*.ts",
    "scripts/**/*.ts"
  ]
}
